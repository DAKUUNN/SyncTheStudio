rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return firestore.get(/databases/(default)/documents/users/$(uid));
    }

    function userExists(uid) {
      return firestore.exists(/databases/(default)/documents/users/$(uid));
    }

    function isAdmin() {
      return signedIn() && userExists(request.auth.uid) && userDoc(request.auth.uid).data.role == 'admin';
    }

    function canAccessProject(projectId) {
      return signedIn() && (
        isAdmin() ||
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)/projects/$(projectId)) ||
        (
          firestore.exists(/databases/(default)/documents/shared_projects/$(projectId)) &&
          (
            firestore.get(/databases/(default)/documents/shared_projects/$(projectId)).data.ownerId == request.auth.uid ||
            request.auth.uid in firestore.get(/databases/(default)/documents/shared_projects/$(projectId)).data.sharedWith
          )
        )
      );
    }

    // Public share links: gated purely by a boolean flag on the (otherwise
    // private) `projects/{projectId}` Firestore document. `firestore.get()`
    // here is a Storage-rules-internal lookup for rule evaluation only — it
    // never exposes the document's contents to the requesting client, so
    // this cannot leak the project's contentKey or any other private field.
    function hasActiveMasterShare(projectId) {
      return firestore.exists(/databases/(default)/documents/projects/$(projectId)) &&
        firestore.get(/databases/(default)/documents/projects/$(projectId)).data.masterShareActive == true;
    }

    function hasActiveCustomerUpload(projectId) {
      return firestore.exists(/databases/(default)/documents/projects/$(projectId)) &&
        firestore.get(/databases/(default)/documents/projects/$(projectId)).data.customerUploadActive == true;
    }

    match /avatars/{userId}/{fileName} {
      allow read: if signedIn();
      allow write: if isAdmin() || (signedIn() && request.auth.uid == userId);
    }

    // NOTE: hasActiveCustomerUpload() is intentionally NOT used as the
    // write gate below. This project's Storage rules cannot reliably call
    // firestore.get()/exists() across services (verified live: it 403s even
    // for a confirmed-active flag with a signed-in, real Firebase Auth
    // session) — a known fragility of this legacy Firebase project, not a
    // data bug. Public uploads instead rely on Firebase Anonymous Auth: the
    // customer page signs the visitor in anonymously before uploading, so
    // `signedIn()` is true. The customerUploadToken itself is still the
    // real gate — it's required earlier to even resolve a projectId via
    // public_uploads/{token} (a same-service Firestore rule, which does
    // work). Whether an uploaded file ever gets linked into the project's
    // attachments list is *also* still gated by isActiveCustomerUpload() in
    // firestore.rules (proven working), so a stray write with a merely-
    // guessed projectId stays an orphaned, invisible Storage object — it can
    // never appear in the app. User explicitly approved this tradeoff.
    match /attachments/{projectId}/{fileName} {
      allow read: if canAccessProject(projectId) || signedIn();
      allow write: if (canAccessProject(projectId) || signedIn()) &&
        request.resource.size < 750 * 1024 * 1024;
    }

    // Voice-note revisions from the public master review page. Same
    // anonymous-auth tradeoff as attachments above; capped much smaller
    // since these are short spoken notes, not full stems.
    match /voiceNotes/{projectId}/{fileName} {
      allow read: if canAccessProject(projectId) || signedIn();
      allow write: if (canAccessProject(projectId) || signedIn()) &&
        request.resource.size < 50 * 1024 * 1024;
    }

    match /files/{projectId}/{fileName} {
      allow read, write: if canAccessProject(projectId);
    }

    match /references/{projectId}/{fileName} {
      allow read, write: if canAccessProject(projectId);
    }

    // Legacy flat path (pre owner-scoped rewrite) — kept for already-
    // uploaded files so old masters don't break.
    match /masters/{projectId}/{fileName} {
      allow read: if canAccessProject(projectId) || hasActiveMasterShare(projectId);
      allow write: if canAccessProject(projectId);
    }

    // canAccessProject() chains several cross-service firestore.get()/
    // exists() calls (isAdmin -> userDoc, own-project exists, shared_projects
    // exists+get). That chain has been observed to 403 live even when every
    // condition is true (same class of fragility documented above for
    // hasActiveCustomerUpload) — most likely the sheer number of chained
    // cross-service lookups in one rule evaluation. Embedding the owner's
    // uid in the path lets the overwhelmingly common case (the owner
    // reading/writing their own master) skip cross-service lookups
    // entirely: a pure request.auth.uid check, which is 100% reliable.
    match /masters/{ownerId}/{projectId}/{fileName} {
      allow read, write: if signedIn() && request.auth.uid == ownerId;
      allow read, write: if isAdmin();
      allow read, write: if signedIn() &&
        firestore.exists(/databases/(default)/documents/shared_projects/$(projectId)) &&
        request.auth.uid in firestore.get(/databases/(default)/documents/shared_projects/$(projectId)).data.sharedWith;
      allow read: if hasActiveMasterShare(projectId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
